# CatBowlWatch — Demo environment
# Copy this file to .env and fill in your Telegram credentials before running:
#   docker compose -f docker/demo.yml up

# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABC-your-bot-token-here
TELEGRAM_CHAT_ID=987654321

# ── Demo overrides ────────────────────────────────────────────────────────────
# Shorter debounce so the demo fires ~15 s after service start.
# Production default is 60. Change here only; never hardcode in source.
DEBOUNCE_SECONDS=8

# Alert cooldown (seconds between repeated alerts for the same bowl).
# Production default is 300.
ALERT_COOLDOWN_SECONDS=60

# ── Inference ─────────────────────────────────────────────────────────────────
INFERENCE_BACKEND=onnx
MODEL_PATH=/models/catbowlwatch.onnx
CONFIDENCE_THRESHOLD=0.50
IOU_THRESHOLD=0.45

# ── Video source ──────────────────────────────────────────────────────────────
# Path inside the container; mapped from data/videos/ by docker-compose.
VIDEO_SOURCE=/data/videos/sample_video.mp4

# ── HTTP service ──────────────────────────────────────────────────────────────
HTTP_PORT=8080

# ── Low-light adaptive preprocessing ─────────────────────────────────────────
# Mean frame brightness threshold (0–255) below which the low-light transform is applied.
BRIGHTNESS_THRESHOLD=50
