# Force LF line endings on files that must be executed in Linux (WSL/Jetson).
# Without this, Git on Windows checks them out with CRLF and bash refuses to
# run them ("$'\r': command not found").
*.sh         text eol=lf
Makefile     text eol=lf

# C++ source: LF everywhere keeps diffs clean across platforms.
*.cpp        text eol=lf
*.h          text eol=lf
*.hpp        text eol=lf
*.cmake      text eol=lf
CMakeLists.txt text eol=lf
